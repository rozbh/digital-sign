{
  "dependencies": {
    "commander": "^14.0.3"
  },
  "bin": "dist/index.js",
  "pkg": {
    "targets": [
      "node24-win-x64",
      "node24-linux-x64"
    ],
    "outputPath": "build"
  },
  "name": "asymmetric-encryption",
  "version": "1.0.0",
  "main": "src/index.ts",
  "scripts": {
    "build": "tsc",
   "bundle": "esbuild src/index.ts --bundle --platform=node --target=node22 --outfile=dist/bundle.js --minify --tree-shaking=true --external:crypto --external:fs --external:path --external:os",
   "build-app": "npm run bundle && pkg . --out-path build"
  },
  "author": "",
  "license": "ISC",
  "description": "",
  "devDependencies": {
    "@types/node": "^18.19.130",
    "@yao-pkg/pkg": "^6.14.2",
    "esbuild": "^0.28.0"
  }
}